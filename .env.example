# ── Tört Qatar — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values

# Server port (default: 3000)
PORT=3000

# Anthropic API key — required for AI Coach post-game analysis
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Stripe secret key — required for real Pro subscription checkout
# Get yours at https://dashboard.stripe.com/apikeys
# Leave blank to use the stub (shows a test URL)
STRIPE_SECRET_KEY=sk_test_...
