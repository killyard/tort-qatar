# ── Tört Qatar — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values

# Server port (default: 3000)
PORT=3000

# Google Gemini API key — required for AI Coach post-game analysis
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Stripe secret key — required for real Pro subscription checkout
# Get yours at https://dashboard.stripe.com/apikeys
# Leave blank to use the stub
STRIPE_SECRET_KEY=sk_test_...
