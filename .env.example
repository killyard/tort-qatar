# ── Tört Qatar — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values

# Server port (default: 3000)
PORT=3000

# Public URL — used to build the Google OAuth callback URL
# Dev: leave blank (defaults to http://localhost:3000)
# Prod: set to your Render URL, e.g. https://tort-qatar.onrender.com
BASE_URL=https://tort-qatar.onrender.com

# Google OAuth — get credentials at https://console.cloud.google.com
# Authorized redirect URI: ${BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session secret — any long random string, keep it private
SESSION_SECRET=your-random-32-char-secret-here

# Google Gemini API key — required for AI Coach post-game analysis
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Groq API key — required for Steppe Bot in-game chat (faster responses)
# Get yours at https://console.groq.com
GROQ_API_KEY=gsk_...

# Stripe secret key — required for real Pro subscription checkout
# Get yours at https://dashboard.stripe.com/apikeys
# Leave blank to use the stub
STRIPE_SECRET_KEY=sk_test_...
